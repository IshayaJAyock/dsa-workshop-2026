# ==========================
# Generative AI Workshop — environment template
# ==========================
#
# Setup (run once from the project folder):
#   cp .env.example .env
#
# Then open .env and paste your API keys. Do NOT commit .env to git.
# This file (.env.example) is safe to share — values are empty placeholders.
#
# You only need ONE cloud provider key, or use Ollama locally with no cloud key.
#
# ==========================
# Frontier / Cloud LLM APIs
# ==========================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

COHERE_API_KEY=
COHERE_MODEL=command-r-plus

# Optional OpenAI-compatible providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

# ==========================
# Local LLM: Ollama
# ==========================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# ==========================
# Optional Tool APIs
# ==========================

STABILITY_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=
